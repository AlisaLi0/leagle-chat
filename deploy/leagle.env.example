# leagle-chat backend environment. Copy to /opt/leagle-chat/leagle.env on the
# server and fill in real values (chmod 600). Never commit the real keys.

# OpenAI-compatible LLM gateway. Backend appends /chat/completions.
LLM_BASE_URL=https://tianshu-gateway.cloud/v1
LLM_API_KEY=__set_me__
LLM_MODEL=auto

# Bind address (kept on loopback; nginx terminates TLS and reverse-proxies).
LEAGLE_HOST=127.0.0.1
LEAGLE_PORT=8600

# Public base URL of the site (used to build OAuth redirect URIs). The frontend
# is served same-origin from this host, so the API, cookies and OAuth callback
# are all first-party.
LEAGLE_PUBLIC_BASE=https://juricodex.online
# Session-cookie path. "/" for the dedicated-domain (same-origin) deployment.
LEAGLE_COOKIE_PATH=/

# Browser origins allowed to call the API. Same-origin needs none, but list the
# canonical hosts so www/apex both work. Use "*" only for local testing.
LEAGLE_CORS_ORIGINS=https://juricodex.online,https://www.juricodex.online

# Per-IP rate limit on /api/chat (the expensive endpoint — each turn fans out to
# several LLM + CourtListener + govinfo/eCFR calls). 0 disables. Requires nginx
# to forward the real client IP (see deploy/nginx-leagle.conf, Cloudflare note).
LEAGLE_CHAT_MAX_PER_HOUR=30
LEAGLE_MAX_CHAT_MESSAGES=20
LEAGLE_MAX_CHAT_MESSAGE_CHARS=50000
LEAGLE_MAX_SESSION_PAYLOAD_BYTES=2000000

# US Code (federal statutes) search needs a free api.data.gov key. Without it the
# US Code source is silently disabled (CFR/case law still work).
# GOVINFO_API_KEY=

# Optional: a free CourtListener API token raises rate limits and unlocks
# opinion-detail endpoints. Anonymous search works without it.
# COURTLISTENER_API_TOKEN=

# Freemius billing (live production values live only in /opt/leagle-chat/leagle.env).
# FREEMIUS_PRODUCT_ID=
# FREEMIUS_PUBLIC_KEY=
# FREEMIUS_SECRET_KEY=
# FREEMIUS_PLANS=pro:52037:68208,max:52038:68209,day_pass:52039:68210
# FREEMIUS_SANDBOX=false
# Optional; defaults in code to https://users.freemius.com/ when unset.
# FREEMIUS_PORTAL_URL=https://users.freemius.com/

# Transactional email (Aliyun Direct Mail / smtpdm) — used to verify a user's
# email when they add/change it in Settings. If unset, email verification is
# disabled and the endpoint won't send (dev surfaces the code instead).
# SMTP_HOST=smtpdm-ap-southeast-1.aliyun.com
# SMTP_PORT=465
# SMTP_USER=noreply@mail.juricodex.online
# SMTP_PASS=__set_me__
# SMTP_FROM=noreply@mail.juricodex.online
# SMTP_FROM_NAME=JuriCodex
# SMTP_SSL=1
