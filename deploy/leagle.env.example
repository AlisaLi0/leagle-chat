# leagle-chat backend environment. Copy to /opt/leagle-chat/leagle.env on the
# server and fill in real values (chmod 600). Never commit the real keys.

# OpenAI-compatible LLM gateway. Backend appends /chat/completions.
LLM_BASE_URL=https://tianshu-gateway.cloud/v1
LLM_API_KEY=__set_me__
LLM_MODEL=auto

# Bind address (kept on loopback; nginx terminates TLS and reverse-proxies).
LEAGLE_HOST=127.0.0.1
LEAGLE_PORT=8600

# Browser origins allowed to call the API. Lock to the static frontend origin
# (e.g. the GitHub Pages site). Use "*" only for local testing.
LEAGLE_CORS_ORIGINS=https://alisali0.github.io

# Per-IP rate limit on /api/chat (the expensive endpoint — each turn fans out to
# several LLM + CourtListener + govinfo/eCFR calls). 0 disables. Requires nginx
# to forward the real client IP (see deploy/nginx-leagle.conf, Cloudflare note).
LEAGLE_CHAT_MAX_PER_HOUR=30

# US Code (federal statutes) search needs a free api.data.gov key. Without it the
# US Code source is silently disabled (CFR/case law still work).
# GOVINFO_API_KEY=

# Optional: a free CourtListener API token raises rate limits and unlocks
# opinion-detail endpoints. Anonymous search works without it.
# COURTLISTENER_API_TOKEN=
